                  <p className="text-slate-400">Monitoring IoT Standards and Asset Liquidity.</p>
                </div>
                <div className="flex space-x-2">
                  <button 
                      onClick={handleScenarioSimulation}
                      disabled={isSimulatingScenario}
                      className="flex items-center space-x-2 bg-rose-600/20 text-rose-400 px-4 py-2 rounded-lg text-sm font-bold border border-rose-500/30 hover:bg-rose-600/30 transition-colors disabled:opacity-50"
