                                  {entity.status}
                               </span>
                            </td>
                            <td className="p-4 font-mono text-emerald-400">{entity.yieldEfficiency}</td>
                            <td className="p-4 text-right">
                               <button 
                                  onClick={() => handleRegistryAudit(entity)}
                                  disabled={isAuditingRegistry}
                                  className="p-2 bg-slate-800 hover:bg-slate-700 text-cyan-400 rounded-lg transition-colors border border-slate-700 flex items-center space-x-1 ml-auto"
                               >
                                  {isAuditingRegistry ? <Loader size={14} className="animate-spin" /> : <Search size={14} />}
                                  <span className="text-xs font-bold">VERIFY NODE</span>
