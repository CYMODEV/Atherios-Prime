                </div>
             </div>
          </div>
        )}

        {/* REGISTRY (NEW TAB for completeness) */}
        {activeTab === 'registry' && (
          <div className="space-y-6">
             <div className="flex justify-between items-end mb-4">
                <div>
                   <h1 className="text-3xl font-bold text-white mb-2">Health Ring Registry</h1>
                   <p className="text-slate-400">Verified Network Nodes & Practitioners.</p>
                </div>
             </div>

             {registryInsight && (
                <div className="mb-6 bg-cyan-900/10 border border-cyan-500/20 p-4 rounded-2xl animate-in fade-in">
