                            <Wrench size={12} />
                            <span className="text-xs font-bold uppercase">Remediation Plan</span>
                          </div>
                          <p className="text-xs text-purple-200/80 leading-relaxed whitespace-pre-line">{remediationPlan}</p>
                      </div>
                   )}

                   <div className="space-y-3 max-h-80 overflow-y-auto pr-2">
                      {complianceLogs.map((log, i) => (
                         <div key={i} className="p-3 bg-slate-900 rounded-xl border border-slate-800 flex justify-between items-center">
                            <div>
                               <div className="text-sm font-bold text-white">{log.event}</div>
                               <div className="text-xs text-slate-500">Node: {log.node}</div>
                            </div>
                            <div className="flex items-center space-x-2">
                               <span className={`text-xs px-2 py-1 rounded border ${
                                  log.impact === 'High' ? 'border-rose-500/30 text-rose-400 bg-rose-500/10' : 'border-emerald-500/30 text-emerald-400 bg-emerald-500/10'
                               }`}>
                                  {log.status}
                               </span>
                               <button 
                                  onClick={() => handleGenerateRemediation(log)}
                                  disabled={isGeneratingRemediation}
                                  className="p-1.5 bg-slate-800 hover:bg-slate-700 text-purple-400 rounded-lg transition-colors border border-slate-700"
                                  title="Suggest Fix"
                                >
                                  {isGeneratingRemediation ? <Loader size={14} className="animate-spin" /> : <Wrench size={14} />}
