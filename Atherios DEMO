                </table>
             </div>
          </div>
        )}

         {/* ASSET MINTING */}
         {activeTab === 'minting' && (
          <div className="space-y-6">
            <h2 className="text-3xl font-bold text-white mb-6">Digital Asset Minting</h2>
            
            <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
              {/* Asset Creation Form */}
              <div className="bg-[#0c0e18] p-6 rounded-2xl border border-slate-800">
                <div className="flex justify-between items-center mb-4">
                  <h3 className="text-lg font-bold text-white">Create New Asset</h3>
                  <button 
                    onClick={handleGenerateAsset}
                    disabled={isMintingAI}
                    className="flex items-center space-x-2 bg-emerald-600/20 text-emerald-400 px-3 py-1.5 rounded-lg text-xs font-bold border border-emerald-500/30 hover:bg-emerald-600/30 transition-colors disabled:opacity-50"
