                    <label className="block text-xs uppercase text-slate-500 mb-1">Asset Title</label>
                    <input 
                      type="text" 
                      value={assetName}
                      onChange={(e) => setAssetName(e.target.value)}
                      className="w-full bg-slate-900 border border-slate-700 rounded-lg p-3 text-white focus:outline-none focus:border-emerald-500" 
                      placeholder="E.g. Bio-Yield Stream #404" 
                    />
                  </div>
                  {assetDesc && (
                    <div className="animate-in fade-in slide-in-from-top-2">
                       <label className="block text-xs uppercase text-slate-500 mb-1">Asset Metadata</label>
                       <textarea 
                        value={assetDesc}
                        readOnly
                        className="w-full bg-slate-900/50 border border-emerald-500/30 rounded-lg p-3 text-emerald-200 text-sm h-24 focus:outline-none resize-none"
                       />
                    </div>
                  )}

                  <button 
                     onClick={handleGenerateContract}
                     disabled={isGeneratingContract}
                     className="w-full flex items-center justify-center space-x-2 bg-slate-800 hover:bg-slate-700 text-emerald-400 font-bold py-3 rounded-lg border border-slate-700 transition-colors"
                  >
                     {isGeneratingContract ? <Loader className="animate-spin" size={16} /> : <Code size={16} />}
                     <span>DRAFT CONTRACT LOGIC</span>
                  </button>

                  {contractLogic && (
                     <div className="bg-slate-950 p-4 rounded-lg border border-slate-800 font-mono text-xs text-emerald-500 max-h-32 overflow-y-auto">
                        <pre>{contractLogic}</pre>
                     </div>
                  )}

                  <button 
                    onClick={handleMintToBlockchain}
                    className="w-full bg-emerald-600 hover:bg-emerald-500 text-white font-bold py-3 rounded-lg transition-colors mt-2"
                  >
                    MINT TO BLOCKCHAIN
                  </button>
                </div>
              </div>

              {/* Asset Mint List Engine */}
              <div className="bg-[#0c0e18] p-6 rounded-2xl border border-slate-800 flex flex-col">
                 <div className="flex justify-between items-center mb-4">
                    <h3 className="text-lg font-bold text-white flex items-center space-x-2">
                       <List size={20} className="text-emerald-400"/>
                       <span>Asset Mint List Engine</span>
                    </h3>
                    <button 
                      onClick={handleAssetValuation}
                      disabled={isValuatingAssets}
                      className="flex items-center space-x-2 bg-slate-800 hover:bg-slate-700 text-emerald-400 px-3 py-1.5 rounded-lg text-xs font-bold transition-colors disabled:opacity-50 border border-slate-700"
                    >
                      {isValuatingAssets ? <Loader className="animate-spin" size={14} /> : <TrendingUp size={14} />}
                      <span>CHECK LIQUIDITY</span>
                    </button>
                 </div>

                 {valuationInsight && (
                     <div className="mb-4 bg-emerald-900/10 border border-emerald-500/20 p-3 rounded-xl animate-in fade-in">
                        <div className="flex items-center space-x-2 text-emerald-400 mb-1">
                           <Sparkles size={12} />
                           <span className="text-xs font-bold uppercase">Liquidity Oracle</span>
                        </div>
                        <p className="text-xs text-emerald-200/80 leading-relaxed">{valuationInsight}</p>
                     </div>
                 )}

                 <div className="overflow-x-auto flex-1">
                    <table className="w-full text-left text-sm">
                       <thead className="bg-slate-900 text-slate-500 uppercase text-xs">
                          <tr>
                             <th className="p-3 rounded-tl-lg">ID</th>
                             <th className="p-3">Name</th>
                             <th className="p-3">Value (kJ)</th>
                             <th className="p-3 rounded-tr-lg">Status</th>
                          </tr>
                       </thead>
                       <tbody className="divide-y divide-slate-800">
                          {mintedAssets.map((asset, i) => (
                             <tr key={i} className="hover:bg-slate-800/50 transition-colors">
                                <td className="p-3 font-mono text-emerald-400 text-xs">{asset.id}</td>
                                <td className="p-3">
                                   <div className="font-medium text-white">{asset.name}</div>
                                   <div className="text-xs text-slate-500">{asset.type}</div>
                                </td>
                                <td className="p-3 font-mono text-white">{asset.value.toLocaleString()}</td>
                                <td className="p-3">
                                   <span className={`px-2 py-1 rounded text-xs border ${
                                      asset.status === 'Minted' ? 'border-emerald-500/30 text-emerald-400 bg-emerald-500/10' :
                                      asset.status === 'Staked' ? 'border-indigo-500/30 text-indigo-400 bg-indigo-500/10' :
                                      'border-slate-600 text-slate-400'
                                   }`}>
                                      {asset.status}
                                   </span>
                                </td>
                             </tr>
                          ))}
                       </tbody>
                    </table>
                 </div>
              </div>
            </div>
          </div>
        )}

      </main>
    </div>
  );
}


