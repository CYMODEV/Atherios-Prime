             <div className="bg-[#0c0e18] rounded-2xl border border-slate-800 overflow-hidden">
                <table className="w-full text-left text-sm">
                   <thead className="bg-slate-900 text-slate-500 uppercase text-xs">
                      <tr>
                         <th className="p-4">Node ID</th>
                         <th className="p-4">Entity Name</th>
