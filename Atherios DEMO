                      {betsRecommendation}
                    </p>
                  </div>
                )}
              </div>
            </div>

            {/* REPAIRED: Active Session Registry */}
            <div className="bg-[#0c0e18] p-6 rounded-2xl border border-slate-800">
                <div className="flex justify-between items-center mb-4">
                   <h3 className="text-lg font-bold text-white flex items-center space-x-2">
