                      className="flex-1 bg-slate-800 border-none rounded-lg px-4 py-2 text-sm text-white focus:ring-1 focus:ring-emerald-500 outline-none"
                    />
                    <button 
                      onClick={handleAgentChat}
                      disabled={isAgentTyping || !chatInput}
                      className="bg-emerald-600 hover:bg-emerald-500 disabled:opacity-50 text-white p-2 rounded-lg transition-colors"
