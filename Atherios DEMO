                               </td>
                               <td className="p-3 font-mono text-emerald-400">+{sess.yield}</td>
                               <td className="p-3 text-right">
                                  <button 
                                    onClick={() => handleGenerateSessionLog(sess)}
                                    disabled={isGeneratingLog}
                                    className="p-1.5 bg-slate-800 hover:bg-slate-700 text-emerald-400 rounded-lg transition-colors border border-slate-700"
                                    title="Generate Log"
                                  >
                                    {isGeneratingLog ? <Loader size={14} className="animate-spin" /> : <ClipboardList size={14} />}
